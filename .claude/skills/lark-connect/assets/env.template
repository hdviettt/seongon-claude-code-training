# Lark Open Platform credentials (tenant mode - bot only)
# Tao tu https://open.larksuite.com -> Developer Console -> Custom App
# Xem chi tiet: .claude/skills/lark-connect/references/lark-platform-setup.md

LARK_APP_ID=cli_<paste-vao-day>
LARK_APP_SECRET=<paste-vao-day>

# Domain - chon dung region khi tao app
# - Lark Suite (international, gom VN): https://open.larksuite.com
# - Feishu (China only): https://open.feishu.cn
# App tao region nao, dung domain region do - khong cross-platform.
LARK_DOMAIN=https://open.larksuite.com

# Token mode - skill chi support tenant_access_token
# (user_access_token co bug voi Larksuite - error 20029 du setup chuan)
LARK_TOKEN_MODE=tenant_access_token

# (Optional) Custom tool list - comma-separated
# Vd: im.v1.message.create,preset.calendar.default,preset.docx.default
# De trong = default preset (~17 tools: im, bitable, docx, sheets, contact)
LARK_TOOLS=
